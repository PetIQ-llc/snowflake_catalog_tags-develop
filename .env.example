# Coalesce Catalog API Configuration
# Copy this file to .env and fill in your actual values

# Your Coalesce Catalog API Token
# Get this from your user settings in the Coalesce Catalog UI
# Visit: https://app.us.castordoc.com/ -> Settings -> API Tokens
COALESCE_API_TOKEN=your_api_token_here

# GraphQL API Endpoint (optional - defaults to standard endpoint)
# Default: https://api.castordoc.com/graphql
# You may need to adjust this based on your region or instance
COALESCE_API_URL=https://api.castordoc.com/graphql